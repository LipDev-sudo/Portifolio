# =============================================================================
# Server-side contact configuration (recomendado em producao)
# =============================================================================
# Estas variaveis sao lidas APENAS no servidor pela rota /api/contact e nunca
# sao expostas no bundle do navegador. Use estas em vez das NEXT_PUBLIC_* sempre
# que possivel.
#
# Onde achar cada valor: https://dashboard.emailjs.com/admin
#   - SERVICE_ID:     Email Services -> selecione o servico -> Service ID
#   - TEMPLATE_ID:    Email Templates -> selecione o template -> Template ID
#   - PUBLIC_KEY:     Account -> General -> Public Key
#   - ACCESS_TOKEN:   Account -> General -> Private Key  (NAO eh a Public Key!)
#                     Sem ela a rota /api/contact retorna 503 e o front-end
#                     cai no fallback client-side toda vez. Configure ela na
#                     Vercel para o pipeline server-side funcionar de verdade.
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_ACCESS_TOKEN=

# Numero de WhatsApp completo com codigo do pais (so digitos), ex: 5581999999999
WHATSAPP_NUMBER=

# URL canonica do site usada na metadata e nos alternates de idioma
SITE_URL=http://localhost:3000

# =============================================================================
# Public fallback variables (expostas no bundle do navegador)
# =============================================================================
# Necessarias para o fallback client-side do formulario de contato funcionar
# quando a rota /api/contact estiver indisponivel (502/503). Tambem usadas pelo
# link direto do WhatsApp e pelo fetch de servicos no client.
#
# IMPORTANTE: garanta que o SERVICE_ID esteja IDENTICO ao do dashboard.
# Um typo ja causou bug em producao (service_ruvpno vs service_rruvpno).
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_SERVICES_API_URL=

# =============================================================================
# Checklist de deploy na Vercel
# =============================================================================
# 1. Configure TODAS as variaveis acima em Project Settings -> Environment
#    Variables (Production + Preview + Development).
# 2. No EmailJS Dashboard -> Account -> Security -> Allowed Origins, adicione
#    o dominio de producao (ex: https://lipdev-portfolio.vercel.app) e qualquer
#    dominio custom. Sem isso, mesmo com IDs corretos, a chamada client-side eh
#    bloqueada.
# 3. Apos qualquer mudanca de env var, faca um redeploy (Vercel nao rebuilda
#    automaticamente quando voce edita variaveis).
